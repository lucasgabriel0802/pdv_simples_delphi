<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <ProjectGuid>{9D4F4C7C-7E36-4A20-9B89-8A2A7DB9E9D4}</ProjectGuid>
    <MainSource>ProjetoVendas.dpr</MainSource>
    <Base>true</Base>
    <Config Condition="'$(Config)'==''">Debug</Config>
    <Platform Condition="'$(Platform)'==''">Win32</Platform>
    <TargetedPlatforms>1</TargetedPlatforms>
    <AppType>Application</AppType>
    <FrameworkType>VCL</FrameworkType>
    <ProjectVersion>20.0</ProjectVersion>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Base)'!=''">
    <DCC_Namespace>System;Xml;Data;Datasnap;Web;Soap;Winapi;Vcl</DCC_Namespace>
    <DCC_UnitSearchPath>src;src\domain;src\application;src\infrastructure;src\presentation</DCC_UnitSearchPath>
    <DCC_DcuOutput>$(PROJECTDIR)\bin\$(Platform)\$(Config)</DCC_DcuOutput>
    <DCC_ExeOutput>$(PROJECTDIR)\bin\$(Platform)\$(Config)</DCC_ExeOutput>
    <DCC_ObjOutput>$(PROJECTDIR)\bin\$(Platform)\$(Config)</DCC_ObjOutput>
    <DCC_HOutput>$(PROJECTDIR)\bin\$(Platform)\$(Config)</DCC_HOutput>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Config)'=='Debug'">
    <DCC_Define>DEBUG;$(DCC_Define)</DCC_Define>
    <DCC_DebugInformation>true</DCC_DebugInformation>
    <DCC_LocalDebugSymbols>true</DCC_LocalDebugSymbols>
    <DCC_Optimize>false</DCC_Optimize>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Config)'=='Release'">
    <DCC_Define>RELEASE;$(DCC_Define)</DCC_Define>
    <DCC_DebugInformation>false</DCC_DebugInformation>
    <DCC_LocalDebugSymbols>false</DCC_LocalDebugSymbols>
    <DCC_Optimize>true</DCC_Optimize>
  </PropertyGroup>

  <ItemGroup>
    <DelphiCompile Include="$(MainSource)">
      <MainSource>MainSource</MainSource>
    </DelphiCompile>
  </ItemGroup>

  <Import Project="$(BDS)\Bin\CodeGear.Delphi.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Delphi.Targets')"/>
  <Import Project="$(APPDATA)\Embarcadero\BDS\$(ProductVersion)\UserTools.proj" Condition="Exists('$(APPDATA)\Embarcadero\BDS\$(ProductVersion)\UserTools.proj')"/>
</Project>
